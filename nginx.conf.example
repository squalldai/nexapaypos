# NexaPay 静态网站 Nginx 配置
# 将此文件复制到 /etc/nginx/sites-available/ 或 include 到 nginx.conf

server {
    listen 80;
    server_name nexapay.com www.nexapos.com;
    
    # 静态文件目录 (将 out 目录内容放到此处)
    root /var/www/nexapos;
    index index.html;
    
    # 开启 gzip 压缩
    gzip on;
    gzip_types text/plain text/css application/json application/javascript text/xml application/xml application/xml+rss text/javascript;
    gzip_min_length 1000;
    
    # 静态资源缓存
    location /_next/static/ {
        expires 365d;
        add_header Cache-Control "public, immutable";
    }
    
    # 图片缓存
    location ~* \.(jpg|jpeg|png|gif|ico|svg|webp)$ {
        expires 30d;
        add_header Cache-Control "public";
    }
    
    # 处理 Next.js 路由 (所有路径都返回 index.html)
    location / {
        try_files $uri $uri/ $uri.html $uri/index.html /index.html;
    }
    
    # 404 页面
    error_page 404 /404.html;
    location = /404.html {
        internal;
    }
    
    # 安全头
    add_header X-Frame-Options "SAMEORIGIN" always;
    add_header X-Content-Type-Options "nosniff" always;
    add_header X-XSS-Protection "1; mode=block" always;
}

# HTTPS 配置 (可选，使用 Let's Encrypt)
